# 通知トリガーになるWi-FiのSSID
TARGET_SSID=WeWorkWiFi

# SSIDがmacOSの位置情報保護でredactされる場合のフォールバック識別子。
# WeWorkのDHCPは search domain として wework.com を配るので、これで判定できる。
TARGET_DNS_DOMAIN=wework.com

# Chatwork APIトークン（https://www.chatwork.com/service/packages/chatwork/subpackages/api/token.php で発行）
CHATWORK_API_TOKEN=

# 通知先のChatworkルームID（URLの末尾の数字）
CHATWORK_NOTIFY_ROOM_ID=
